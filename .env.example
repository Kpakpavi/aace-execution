# ============================================================================
# AACE — environment configuration
# Copy this file to `.env` (gitignored) and fill in real values.
# ============================================================================

# ---------- PostgreSQL (used by api, dashboard, and post-v0.1.0 features) ---

# PostgreSQL host. For local docker-compose, this stays as `postgres`.
POSTGRES_HOST=postgres

# PostgreSQL TCP port inside the container network (default 5432).
POSTGRES_PORT=5432

# Name of the AACE database.
POSTGRES_DB=aace

# PostgreSQL role/user.
POSTGRES_USER=postgres

# Password for POSTGRES_USER.
# CHANGE THIS for any deployed environment. Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=replace-with-a-strong-password

# ---------- API auth -------------------------------------------------------

# Shared secret required in the X-API-Key header on all API endpoints
# except /health. Generate with: openssl rand -hex 32
AACE_API_KEY=replace-with-a-long-random-string

# ---------- Worker / AI-agent webhook (v0.1.0 essentials) -----------------

# The URL where your AI agent listens for scored opportunities.
# For local testing, use a free disposable URL from https://webhook.site
AGENT_WEBHOOK_URL=https://webhook.site/your-unique-id-here

# Shared secret used to HMAC-sign each webhook payload. The AI agent
# must verify this on its side. Generate with: openssl rand -hex 32
AGENT_WEBHOOK_SECRET=replace-with-a-long-random-string

# How often the worker runs one full fetch -> match -> score -> webhook tick.
# Default 30. Lower while tuning, higher to be polite to sources.
WORKER_INTERVAL_MINUTES=30

# Minimum absolute price spread (in USD) for an opportunity to ship.
# Production default $5. Lower for testing, raise to filter noise.
SCORER_MIN_ABS_SPREAD=5.0

# Minimum percentage spread (0.05 = 5%) for an opportunity to ship.
SCORER_MIN_PCT_SPREAD=0.05

# Multiplier applied to percent spread to compute the 0..1 score.
# 2.0 means a 50% spread caps the score at 1.0.
SCORER_PCT_MULTIPLIER=2.0

# Jaccard similarity cutoff (0..1) for two listing titles to be treated
# as the same product by the token-based matcher.
# 0.6 = balanced. Raise to 0.75 for stricter matching, lower to 0.4 to
# see more candidate matches during tuning.
MATCHER_SIMILARITY_THRESHOLD=0.6

# ---------- Observability (optional) --------------------------------------

# Sentry DSN. If set, both api and worker report errors to Sentry.
# Get a DSN at https://sentry.io (free tier is generous).
# Leave blank to disable.
SENTRY_DSN=

# Tag for Sentry events. Helps filter staging vs production.
SENTRY_ENVIRONMENT=production

# Fraction of transactions traced (0.0..1.0). Lower = cheaper.
SENTRY_TRACES_SAMPLE_RATE=0.1

# Worker log verbosity. INFO is fine for production; DEBUG for debugging.
LOG_LEVEL=INFO
