# PostgreSQL host where the AACE database is reachable.
POSTGRES_HOST=localhost

# PostgreSQL TCP port (default 5432).
POSTGRES_PORT=5432

# Name of the AACE database to connect to.
POSTGRES_DB=aace

# PostgreSQL role/user used by the application.
POSTGRES_USER=postgres

# Password for POSTGRES_USER. Replace with a strong secret in real environments.
POSTGRES_PASSWORD=postgres

# Shared secret required in the X-API-Key header on all API endpoints except /health.
AACE_API_KEY=replace-with-a-long-random-string
